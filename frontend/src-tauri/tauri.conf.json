{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "YOLOStudio",
    "version": "0.2.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "sidecar": true,
        "execute": true
      },
      "dialog": {
        "all": true,
        "open": true,
        "save": true
      },
      "notification": {
        "all": true
      },
      "window": {
        "all": true
      },
      "path": {
        "all": true
      },
      "fs": {
        "all": false
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": null,
        "headerImage": null,
        "sidebarImage": null,
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"],
        "customTemplate": null,
        "compression": "lzma",
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        }
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.yolostudio.app",
      "longDescription": "视觉模型工作站 — 数据集管理、模型训练、推理测试",
      "resources": [
        "../../dist/backend/**"
      ],
      "shortDescription": "YOLO 视觉模型工作站",
      "targets": [
        "nsis"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "YOLOStudio",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 660,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": true,
        "focus": true,
        "fileDropEnabled": true,
        "label": "main"
      }
    ]
  }
}